PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/na4wx-allstar-cloud

# Signs short-lived access tokens (~15 min). Rotate by changing this and
# restarting -- every existing access token becomes invalid immediately,
# though refresh tokens (stored hashed in Mongo, see src/models) are
# unaffected and can mint new ones on the next refresh.
JWT_SECRET=change-me-to-a-long-random-value

# HMAC pepper for hashing device API keys before they're stored (see
# src/utils/apiKey.ts) -- never the plaintext key itself. Losing this
# value doesn't expose any key, but rotating it invalidates every
# existing device's ability to authenticate (their hash would no longer
# match), so treat it like any other long-lived secret.
API_KEY_PEPPER=change-me-to-a-different-long-random-value

# Set to "production" to require secure (HTTPS-only) cookies.
NODE_ENV=development

# Only needed if the client is served from a different origin than this
# API (e.g. a separate api-allstar.example.com subdomain, rather than a
# reverse proxy putting both behind one origin). Enables CORS for
# exactly this one origin, with credentials -- leave unset for a
# same-origin deployment (the more common case; no CORS needed then).
# Must match the client's origin exactly, no trailing slash.
#CLIENT_ORIGIN=https://allstar.example.com

# Text-to-speech (see src/services/piperTts.ts) -- runs the Piper
# offline neural TTS engine on this process. Optional: leave both unset
# and the "Generate from text" feature just has no voices to offer.
# PIPER_BIN can be a bare command name (resolved via PATH) or a full
# path. PIPER_VOICES_DIR must contain at least one Piper voice model
# (a matching *.onnx + *.onnx.json pair) -- download the binary and a
# voice the same way HamVoipConfigGui's own install.sh does for the
# node (https://github.com/rhasspy/piper releases; voices at
# https://huggingface.co/rhasspy/piper-voices).
#PIPER_BIN=piper
#PIPER_VOICES_DIR=/etc/na4wx-allstar-cloud/piper-voices

# The browser-facing origin this service is reached at -- embedded in
# password-reset email links (see src/services/mailer.ts). Set this to
# your real public origin in production, or reset links will point at
# localhost. Defaults to the local client dev server.
APP_URL=http://localhost:5173

# SMTP config for password-reset emails (see src/services/mailer.ts).
# Optional: leave SMTP_HOST unset and a "forgot password" request is
# just logged to this process's own stdout instead of emailed --
# useful for local dev, but real users need this configured to actually
# receive a reset link.
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_SECURE=false
#SMTP_USER=apikey
#SMTP_PASS=change-me
#SMTP_FROM=NA4WX Allstar Cloud <no-reply@example.com>
