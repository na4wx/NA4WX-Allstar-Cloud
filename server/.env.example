PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/na4wx-allstar-cloud

# Signs short-lived access tokens (~15 min). Rotate by changing this and
# restarting -- every existing access token becomes invalid immediately,
# though refresh tokens (stored hashed in Mongo, see src/models) are
# unaffected and can mint new ones on the next refresh.
JWT_SECRET=change-me-to-a-long-random-value

# HMAC pepper for hashing device API keys before they're stored (see
# src/utils/apiKey.ts) -- never the plaintext key itself. Losing this
# value doesn't expose any key, but rotating it invalidates every
# existing device's ability to authenticate (their hash would no longer
# match), so treat it like any other long-lived secret.
API_KEY_PEPPER=change-me-to-a-different-long-random-value

# Set to "production" to require secure (HTTPS-only) cookies.
NODE_ENV=development

# Only needed if the client is served from a different origin than this
# API (e.g. a separate api-allstar.example.com subdomain, rather than a
# reverse proxy putting both behind one origin). Enables CORS for
# exactly this one origin, with credentials -- leave unset for a
# same-origin deployment (the more common case; no CORS needed then).
# Must match the client's origin exactly, no trailing slash.
#CLIENT_ORIGIN=https://allstar.example.com
